# Required: this folder stores cover/chapter images, so Apache enters it before root rules run.
# Slug URLs like /manga/one-piece are sent to the info controller; numeric paths stay as files.
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /manga/

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-zA-Z][a-zA-Z0-9\-]*)$ /controllers/mangaInfo_Controller.php?slug=$1 [L,QSA]
</IfModule>
