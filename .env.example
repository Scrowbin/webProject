# Copy to .env and fill in your values

# Public URL (e.g. https://yoursite.infinityfreeapp.com)
APP_URL=

# Site identity (shown on login pages, navbar, About — helps trust / Safe Browsing)
SITE_TITLE=Manga Reading Website
SITE_NAME=MangaDax
SITE_SUBTITLE=Non-commercial student project for learning web development and database systems
SITE_AUTHOR=scrowbin

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=manga
DB_CHARSET=utf8mb4

# SMTP (register / password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=MangaDax
SMTP_DEBUG=0
